          "name": "Interact (v4) — run an agent turn (non-streaming)",
          "request": {
            "name": "Interact (v4) — run an agent turn (non-streaming)",
            "description": {
              "content": "Sends an action to a Voiceflow agent and returns an array of `trace` events\ndescribing what the agent did this turn. Use the `request` action to send\nend-user input; use `launch` to begin a new conversation.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "state",
                "user",
                ":userID",
                "interact"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "userID",
                  "description": "(Required) Stable identifier for the end user / conversation participant."
                }
              ]
            },
            "header": [
              {
                "disabled": false,
                "description": "Project version (defaults to `production`).",
                "key": "versionID",
